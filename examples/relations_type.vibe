int32 i1 = 10;
int32 i2 = 20;

int64 l1 = 5000000000;
int64 l2 = 6000000000;
int64 l_copy = 5000000000;

float32 f1 = 1.5;
float32 f2 = 2.5;
float32 f_copy = 1.5;

float64 d1 = 3.14159;
float64 d2 = 2.71828;

print(l1 == l_copy);
print(l1 != l2);
print(l1 > l2);
print(l1 <= l2);

print(f1 == f_copy);
print(f1 < f2);
print(f1 >= f2);

print(d1 != d2);
print(d1 <= d2);
print(d1 > d2);

print(i1 < f1);
print(l1 > i2);
print(d1 >= f1);
