int32 i2 = 0 - 5;
int32 i3 = 0;

float64 d1 = 10.5;
float64 d2 = 10.0;
float64 d3 = 0 - 5.5;
float64 d4 = 0.0;

print(i1 < d1);   
print(i1 == d2);  
